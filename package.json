{
  "name": "modal-templates",
  "version": "1.1.1",
  "description": "Block-based modal plugin for WordPress",
  "files": [
    "assets/",
    "build/",
    "includes/register-blocks.php",
    "includes/settings.php",
    "includes/template-parts.php",
    "lib/",
    "modal-templates.php",
    "readme.txt",
    "README.md",
    "uninstall.php"
  ],
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "format": "wp-scripts format",
    "lint:js": "wp-scripts lint-js src/ assets/js/ webpack.config.js",
    "lint:css": "wp-scripts lint-style assets/css/ src/**/*.css",
    "lint:php": "composer run-script lint",
    "lint": "npm run lint:js && npm run lint:css && composer run-script lint",
    "i18n:pot": "wp i18n make-pot . languages/modal-templates.pot --domain=modal-templates --exclude=build,node_modules,vendor",
    "i18n:mo": "wp i18n make-mo languages/",
    "i18n:json": "wp i18n make-json languages/ --no-purge",
    "i18n": "npm run i18n:pot && npm run i18n:mo && npm run i18n:json",
    "plugin-zip": "wp-scripts plugin-zip",
    "test:unit": "wp-scripts test-unit-js",
    "test:e2e": "wp-scripts test-playwright",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:clean": "wp-env clean",
    "test:php": "wp-env run tests-cli --env-cwd wp-content/plugins/modal-templates -- vendor/bin/phpunit"
  },
  "devDependencies": {
    "@wordpress/env": "^11.8.1",
    "@wordpress/scripts": "^32.4.1"
  }
}
