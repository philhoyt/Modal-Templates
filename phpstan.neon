includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    bootstrapFiles:
        - phpstan-bootstrap.php
    paths:
        - includes
        - modal-templates.php
    excludePaths:
        # Marked optional with (?) so analysis doesn't error in environments
        # where these aren't present (e.g. the CI php job skips npm install/build).
        - vendor (?)
        - node_modules (?)
        - build (?)
        - tests (?)
